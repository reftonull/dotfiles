# ── Environment ──────────────────────────────────────────────────────────────
set -gx EDITOR nvim

# ── PATH ─────────────────────────────────────────────────────────────────────
fish_add_path ~/.local/bin

# ── tmux Auto-Start ──────────────────────────────────────────────────────────
# Show session picker with fzf or create new session.
# Skipped inside Neovim terminals, SSH, and non-interactive shells.
if status is-interactive
    and not set -q TMUX
    and not set -q NVIM
    and not set -q SSH_TTY
    and not set -q VSCODE_INJECTION

    set sessions (tmux list-sessions -F '#S' 2>/dev/null)

    if test (count $sessions) -gt 0
        # Add "Create new session" as an option
        set choice (begin
            printf "%s\n" $sessions
            echo "+ Create new session"
        end | fzf --prompt="tmux> " --height=40% --border)

        if test "$choice" = "+ Create new session"
            read -P "Session name: " session_name
            if test -n "$session_name"
                tmux new-session -s $session_name
            end
        else if test -n "$choice"
            tmux attach -t $choice
        end
    else
        # No sessions exist, create first one
        read -P "Create first tmux session? (y/n) " -n 1 create
        if test "$create" = y
            read -P "Session name (default: main): " session_name
            if test -z "$session_name"
                set session_name main
            end
            tmux new-session -s $session_name
        end
    end
end

# ── Aliases ──────────────────────────────────────────────────────────────────
alias nv="nvim"
alias gs="gt sync --force"
alias gss="gt submit --stack"
alias gls="gt ls"
alias wm="workmux"
alias wma="workmux add"
alias wml="workmux list"
alias wmm="workmux merge"
alias wmr="workmux remove"
alias wmd="workmux dashboard"
alias cat="bat"
alias ls="eza"
alias ll="eza -la --git"
alias tree="eza --tree"
alias lg="lazygit"

# ── Integrations ─────────────────────────────────────────────────────────────
# zoxide (smart cd)
zoxide init fish --cmd cd | source
alias z="cd"

# OrbStack
source ~/.orbstack/shell/init2.fish 2>/dev/null; or true
